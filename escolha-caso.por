programa {
    funcao inicio(){
        inteiro opcao

        escreva("1-listar")
        escreva("2-Cadastrar")
        leia(opcao)
escolha(opcao) {
        caso 1:
        escreva("listar")
        pare

        caso 2:
        escreva("Cadastrar") 
        pare

        caso contrario:
        escreva("Nenhuma opção selecionado.")
        pare
      }
    }
}